# ============================================================
#  TRAVEL GURU — Environment Variables
#  Uses LOCAL MongoDB (via Docker). No Atlas needed.
# ============================================================

# Local MongoDB — works with docker-compose (recommended)
MONGO_URI=mongodb://127.0.0.1:27017/travelguru

# If you prefer MongoDB Atlas, replace the line above with:
# MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASS@cluster0.xxxxx.mongodb.net/travelguru

# JWT Secret — do NOT change after users sign up
JWT_SECRET=TravelGuru_India_2025_MySecretKey_xK9pL2mQ

# Admin login credentials
ADMIN_ID=admin@travelguru.in
ADMIN_PASS=Admin@TG2025#Secure

# Server port
PORT=8080
